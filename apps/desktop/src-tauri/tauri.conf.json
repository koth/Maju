{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Maju",
  "version": "0.1.5",
  "identifier": "com.kodex.editor",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "../ui"
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "../ui"
    }
  },
  "app": {
    "windows": [
      {
        "title": "Maju",
        "width": 1440,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.kodex/attachments/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
      "resources": {
        "resources/codex-acp/*": "bundled-codex-acp/",
        "resources/claude-agent-acp": "bundled-claude-agent-acp"
      },
    "windows": {
      "nsis": {
        "installerHooks": "nsis/maju-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM3NUNFRTFEMUUyQUY3QUIKUldTcjl5b2VIZTVjeDBnbldyeWQ3UkFtYzVoUGNobFREZGNaYnRNZUVtQW5RUU4wVFRJV081Z3EK",
      "endpoints": [
        "https://github.com/koth/Kodex/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
