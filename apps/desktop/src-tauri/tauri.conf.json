{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Kodex",
  "version": "0.1.0",
  "identifier": "com.kodex.editor",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "../ui"
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "../ui"
    }
  },
  "app": {
    "windows": [
      {
        "title": "Kodex",
        "width": 1440,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/codex-acp/*": "bundled-codex-acp/",
      "resources/claude-agent-acp": "bundled-claude-agent-acp"
    },
    "windows": {
      "nsis": {
        "installerHooks": "nsis/kodex-hooks.nsh"
      }
    }
  }
}
