{
  "name": "maju-ui",
  "private": true,
  "version": "0.1.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "codex:build": "cd ../../../codex-acp && cargo build --release",
    "codex:stage": "node scripts/stage-codex-acp.mjs",
    "codex:binary": "npm run codex:build && npm run codex:stage",
    "claude:build": "npm --prefix ../../../kodex-claude run build",
    "claude:stage": "node scripts/stage-claude-agent-acp.mjs",
    "claude:binary": "npm --prefix ../../../kodex-claude run build:binary && npm run claude:stage",
    "build:with-claude": "npm run build && npm run claude:binary && npm run codex:binary",
    "desktop:build": "npm run claude:binary && npm run codex:binary && cd ../src-tauri && tauri build --ci",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@pierre/diffs": "^1.1.20",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-process": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "ghostty-web": "^0.4.0",
    "lucide-react": "^1.20.0",
    "monaco-editor": "^0.50.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.6.1",
    "remark-gfm": "^4.0.1",
    "tm-grammars": "^1.31.15",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
