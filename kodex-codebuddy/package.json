{
  "name": "kodex-codebuddy-proxy",
  "version": "0.0.0-private",
  "description": "Proxy that exposes CodeBuddy model capabilities via an OpenAI/Anthropic-compatible HTTP surface",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node dist/index.js",
    "dev": "npm run build && npm run start",
    "build": "tsc",
    "build:binary": "node scripts/build-sea.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.25.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tencent-ai/agent-sdk": "0.3.197",
    "express": "^4.21.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "postject": "^1.0.0-alpha.6",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
